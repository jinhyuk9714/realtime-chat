        <mxCell id="note" value="Core: WebSocket connection, Kafka publish, DB persisted, receiver delivery are separate boundaries.&lt;br&gt;Redis Presence is ephemeral. PostgreSQL is the recovery truth for reconnect sync." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#334155;" vertex="1" parent="1">
